# =============================================================================
# scripts/.env — Variables de entorno para el smoke diario
#
# INSTRUCCIONES:
#   1. Copia este archivo: cp scripts/.env.example scripts/.env
#   2. Rellena los valores
#   3. .env está en .gitignore — nunca se sube a GitHub
# =============================================================================

# URL del Incoming Webhook de Slack
# Cómo obtenerla: https://api.slack.com/messaging/webhooks
#   1. Ir a https://api.slack.com/apps → Create New App → From scratch
#   2. Activar "Incoming Webhooks"
#   3. "Add New Webhook to Workspace" → elegir canal (ej: #sdk-qa)
#   4. Copiar el URL que empieza con https://hooks.slack.com/services/...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/TU/WEBHOOK/AQUI

# (Opcional) URL de un dashboard o log viewer para incluir en el mensaje Slack
# Puede ser un link a la carpeta compartida del report, Notion, etc.
SLACK_RUN_URL=
