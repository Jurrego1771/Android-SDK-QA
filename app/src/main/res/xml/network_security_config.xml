<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Solo en builds debug: confiar en certificados CA instalados por el
         usuario (mitmproxy/Charles) para poder inspeccionar tráfico HTTPS,
         incluido el del SDK de IMA. NO afecta builds release. -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
